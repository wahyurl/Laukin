{
    "version": 2,
    "framework": null,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.9.0"
        },
        "api/phpinfo.php": {
            "runtime": "vercel-php@0.9.0"
        }
    },
    "routes": [
        {
            "src": "/api/phpinfo.php",
            "dest": "/api/phpinfo.php"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}